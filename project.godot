[physics]

common/physics_ticks_per_second=120
2d/sleep_threshold_linear=0.0
2d/sleep_threshold_angular=0.0
2d/time_before_sleep=0.0
2d/default_gravity_vector=Vector2( 0, 1 )
3d/default_gravity_vector=Vector3( 0, 1000, 0 )
common/physics_interpolation=true

[rendering]

environment/defaults/default_clear_color=Color( 0.615686, 0.901961, 0.921569, 1 )
